{
  "manifest_version": 3,
  "name": "AI Voice Control",
  "short_name": "AI Voice Control",
  "version": "8.0.0",
  "description": "AI Voice Control for ChatGPT. Developed by Bruno DELNOZ (@NoXoZ_be). In MAXI mode, click @NoXoZ_be to contact the developer.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://www.claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://www.claude.ai/*"
      ],
      "js": [
        "content-autosend.js"
      ],
      "css": [
        "autosend-style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Voice Control",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "version_name": "v8.0.0 Runtime"
}
