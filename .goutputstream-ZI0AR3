    background: var(--cgas-read-bg);
    border-color: var(--cgas-read-border);
    color: var(--cgas-read-text);
}

#cgas-mini-readaloud.cgas-mini-readaloud-on {
    background: var(--cgas-on-bg);
    border-color: var(--cgas-on-border);
    color: var(--cgas-on-text);
}

