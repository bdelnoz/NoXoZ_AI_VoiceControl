:root {
    --cgas-on-bg: rgba(132, 204, 22, 0.94);
    --cgas-on-border: rgba(217, 249, 157, 0.96);
    --cgas-on-text: #111827;

    --cgas-off-bg: rgba(147, 197, 253, 0.82);
    --cgas-off-border: rgba(191, 219, 254, 0.96);
    --cgas-off-text: #0f172a;

    --cgas-read-bg: rgba(244, 114, 182, 0.82);
    --cgas-read-border: rgba(251, 207, 232, 0.98);
    --cgas-read-text: #2a0d1f;

    --cgas-group-border: rgba(190, 242, 100, 0.58);
    --cgas-group-glow: rgba(132, 204, 22, 0.12);
}

/* Clickable feedback badge. */
#cgas-mini-brand-badge {
    text-decoration: none;
    cursor: pointer;
}

#cgas-mini-brand-badge:hover {
    color: rgba(236, 252, 203, 0.98);
    text-decoration: underline;
}

/* State buttons: green ON, pastel blue OFF. */
#cgas-mini-tos-toggle.cgas-mini-tos-on,
#cgas-mini-send-toggle.cgas-mini-send-on,
#cgas-mini-trigger-readaloud.cgas-mini-trigger-readaloud-on {
    background: var(--cgas-on-bg);
    border-color: var(--cgas-on-border);
    color: var(--cgas-on-text);
}

#cgas-mini-tos-toggle.cgas-mini-tos-off,
#cgas-mini-send-toggle.cgas-mini-send-off,
#cgas-mini-trigger-readaloud.cgas-mini-trigger-readaloud-off {
    background: var(--cgas-off-bg);
    border-color: var(--cgas-off-border);
    color: var(--cgas-off-text);
}

/* ReadAloud actions: pink family, except Set ReadAloud Mode when active. */
#cgas-mini-readaloud.cgas-mini-readaloud-off,
