    font-size: 7.2px;
    line-height: 1.03;
    white-space: normal;
}

#cgas-mini-widget:not(.cgas-mini-maximized):not(.cgas-mini-minimized) #cgas-mini-tos-box,
#cgas-mini-widget:not(.cgas-mini-maximized):not(.cgas-mini-minimized) #cgas-mini-status,
