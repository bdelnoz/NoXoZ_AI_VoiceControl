    min-height: 23px;
    font-size: 9px;
}


/* =============================================================================
   v7.8 STABLE UI OVERRIDES — NO MANUAL RESIZING
   ============================================================================= */

:root {
    --cgas-v78-read-bg: rgba(5, 8, 10, 0.98);
    --cgas-v78-read-text: #b7ff35;
    --cgas-v78-read-border: rgba(244, 114, 182, 0.98);
    --cgas-v78-read-glow: rgba(244, 114, 182, 0.18);
}

/* Explicitly disable every browser resize path. */
#cgas-mini-widget,
#cgas-mini-widget.cgas-mini-maximized,
#cgas-mini-widget.cgas-mini-minimized,
#cgas-mini-widget:not(.cgas-mini-maximized):not(.cgas-mini-minimized) {
    resize: none !important;
}

/* Wider and more readable MAXI mode. */
#cgas-mini-widget.cgas-mini-maximized {
    width: 184px;
    padding: 8px;
    overflow: visible;
}

#cgas-mini-widget.cgas-mini-maximized #cgas-mini-header {
    grid-template-columns: 21px minmax(0, 1fr) 21px;
    gap: 6px;
}

#cgas-mini-widget.cgas-mini-maximized #cgas-mini-title {
    font-size: 17px;
    line-height: 1.05;
    overflow: visible;
    text-overflow: clip;
    white-space: nowrap;
    text-align: center;
}

#cgas-mini-widget.cgas-mini-maximized #cgas-mini-toggle {
    font-size: 13.5px;
}

#cgas-mini-widget.cgas-mini-maximized #cgas-mini-tos-toggle,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-send-toggle,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-trigger-readaloud,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-readaloud,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-start-readaloud,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-stop-readaloud,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-reload-ext,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-platform-mode {
    font-size: 11.5px;
    line-height: 1.08;
}

#cgas-mini-widget.cgas-mini-maximized #cgas-mini-tos-toggle,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-send-toggle,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-trigger-readaloud {
    min-height: 32px;
}

#cgas-mini-widget.cgas-mini-maximized #cgas-mini-readaloud {
    min-height: 31px;
}

#cgas-mini-widget.cgas-mini-maximized #cgas-mini-start-readaloud,
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-stop-readaloud {
    min-height: 36px;
    font-size: 10.5px;
}

/* ReadAloud: black inside, neon-green text, pink contour. */
#cgas-mini-readaloud.cgas-mini-readaloud-off,
#cgas-mini-start-readaloud,
#cgas-mini-start-readaloud.cgas-mini-start-readaloud-on,
#cgas-mini-stop-readaloud,
#cgas-mini-stop-readaloud.cgas-mini-stop-readaloud-active {
    background: var(--cgas-v78-read-bg);
    border-color: var(--cgas-v78-read-border);
    color: var(--cgas-v78-read-text);
    box-shadow: 0 0 0 1px var(--cgas-v78-read-glow);
    text-shadow: 0 0 5px rgba(183, 255, 53, 0.20);
}

#cgas-mini-readaloud.cgas-mini-readaloud-on {
    background: rgba(132, 204, 22, 0.94);
    border-color: var(--cgas-v78-read-border);
    color: #111827;
    box-shadow: 0 0 0 1px var(--cgas-v78-read-glow);
}


/* =============================================================================
   v8.0.0 — TITLE SIZE ONLY
   ============================================================================= */
#cgas-mini-widget.cgas-mini-maximized #cgas-mini-title {
    font-size: 13px;
}

#cgas-mini-widget:not(.cgas-mini-maximized):not(.cgas-mini-minimized) #cgas-mini-title {
    font-size: 8px;
}
